# Copy to .env and fill in real values. .env is gitignored.
# Railway MongoDB — paste the full connection string from the Railway MongoDB addon page.
MONGO_URL=mongodb://user:password@host:port
MONGO_DB=prosperity

# Shared secret for the FastAPI service. Generate with `openssl rand -hex 32`.
PLATFORM_API_KEY=change-me

# Where backtest artifacts + uploaded datasets + uploaded strategies are written.
#   runs:       {STORAGE_ROOT}/runs/<run_id>/
#   datasets:   {STORAGE_ROOT}/data/prices_round_<N>_day_<M>.csv
#   strategies: {STORAGE_ROOT}/strategies/<strategy_id>.py
# On Railway, mount a persistent volume and point this at it.
STORAGE_ROOT=./storage
